{
  "expo": {
    "name": "PetSnap Health Checker",
    "slug": "petsnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "petsnap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4CAF50"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.petsnap.healthchecker",
      "buildNumber": "31",
      "infoPlist": {
        "NSCameraUsageDescription": "PetSnap uses the camera to take photos of your pet's symptoms for health analysis.",
        "NSPhotoLibraryUsageDescription": "PetSnap accesses your photo library to select images of your pet's symptoms.",
        "NSPhotoLibraryAddUsageDescription": "PetSnap saves analysis results to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.petsnap.healthchecker",
      "versionCode": 13,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#4CAF50"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "9b2f7369-5c5c-4ec6-a28b-8cb1da58c532"
      }
    },
    "owner": "aspag"
  }
}